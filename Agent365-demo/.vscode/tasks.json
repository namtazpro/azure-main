{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Construction Agent",
      "type": "shell",
      "command": "dotnet run --project src/ConstructionCompliance.Agent/ConstructionCompliance.Agent.csproj --urls http://localhost:5099",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^.*$",
            "file": 0,
            "location": 1,
            "message": 2
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "Now listening on"
        }
      }
    },
    {
      "label": "Stop All Tasks",
      "type": "shell",
      "command": "echo ${input:terminate}",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "terminate",
      "type": "command",
      "command": "workbench.action.tasks.terminate",
      "args": "terminateAll"
    }
  ]
}
